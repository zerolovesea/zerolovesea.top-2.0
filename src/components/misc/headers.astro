---
import { menuItems } from "@data/index";
import HeaderLink from "./header-link.astro";
import ThemeSwitcher from "./theme-switcher.astro";

const isEnglish =
	Astro.url.pathname === "/en" || Astro.url.pathname.startsWith("/en/");
const localize = (url: string) =>
	isEnglish ? (url === "/" ? "/en" : `/en${url}`) : url;
const languageHref = isEnglish
	? Astro.url.pathname.replace(/^\/en(?=\/|$)/, "") || "/"
	: `/en${Astro.url.pathname === "/" ? "" : Astro.url.pathname}`;
---

<div class='flex flex-row justify-between items-center w-full max-w-xl'>
	<div class='flex flex-row gap-3 font-medium text-black items-start'>
		{
			menuItems.map((item) => (
				<HeaderLink href={localize(item.url)}>{item.label}</HeaderLink>
			))
		}
	</div>
	<div class='flex items-center gap-1'>
		<a
			href={languageHref}
			class='rounded-full p-2 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors duration-200'
			aria-label={isEnglish ? '切换到中文' : 'Switch to English'}>
			<span class='block min-w-5 text-center text-sm font-medium leading-5' aria-hidden='true'>
				{isEnglish ? '中' : 'EN'}
			</span>
		</a>
		<ThemeSwitcher />
	</div>
</div>
