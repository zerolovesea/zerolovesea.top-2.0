---
import type { GetStaticPaths } from "astro";
import { getCollection, render } from "astro:content";
import { ScrollProgress } from "@components/misc";
import ThoughtsLayout from "@layouts/thoughts-layout.astro";
import WritingLayout from "@layouts/writing-layout.astro";
import { getReadingTime } from "@utils/index";

export const getStaticPaths = (async () => {
	const [writings, thoughts] = await Promise.all([
		getCollection("writing"),
		getCollection("thought"),
	]);

	return [...writings, ...thoughts].map(({ id }) => ({ params: { slug: id } }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;

const writings = await getCollection("writing");
const thoughts = await getCollection("thought");

const writing = writings.find((p) => p.id === slug);
const thought = thoughts.find((p) => p.id === slug);
const post = writing ?? thought;
if (!post) {
	throw new Error(`Missing content for ${slug}`);
}

const { Content } = await render(post);
const readingTime = getReadingTime(post.body ?? "");
---

{writing ? (
	<WritingLayout {...writing.data} readingTime={readingTime}>
		<Content />
		<ScrollProgress />
	</WritingLayout>
) : thought ? (
	<ThoughtsLayout {...thought.data} readingTime={readingTime}>
		<Content />
		<ScrollProgress />
	</ThoughtsLayout>
) : null}
