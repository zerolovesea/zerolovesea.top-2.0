---
import { getCollection } from "astro:content";
import { ThoughtsItem } from "@components/cards";
import { Header } from "@components/misc";
import { BaseHead } from "@components/seo";
import RootLayout from "@layouts/root-layout.astro";

const thoughts = (await getCollection("thoughtEn")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head><BaseHead title="thoughts" description="English translations of Yang Zhou's short-form notes." /></head>
	<RootLayout>
		<div class="flex flex-col w-full gap-6 max-w-xl">
			<Header />
			<h1 class="mb-6 w-full text-7xl font-medium tracking-tight">thoughts</h1>
			{thoughts.map((thought, index) => <ThoughtsItem category={thought.data.category} content={thought.data.description} pubDate={thought.data.pubDate} slug={thought.id} index={index} locale="en" />)}
		</div>
	</RootLayout>
</html>
