{
	"name": "sanju.sh",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "bun run build && ./node_modules/.bin/wrangler dev --config dist/server/wrangler.json --local",
		"start": "bun run dev",
		"build": "./node_modules/.bin/astro check && ./node_modules/.bin/astro build",
		"preview": "bun run dev",
		"astro": "./node_modules/.bin/astro",
		"new": "bun scripts/new-post.ts",
		"test:reading-time": "bun scripts/test-reading-time.ts",
		"check": "biome check ./src",
		"lint": "biome lint ./src",
		"format": "biome format --write ."
	},
	"dependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/cloudflare": "^14.0.0",
		"@astrojs/mdx": "^7.0.0",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.3",
		"@tailwindcss/vite": "^4.3.1",
		"astro": "^7.0.2",
		"katex": "^0.18.1",
		"rehype-katex": "^7.0.1",
		"remark-math": "^6.0.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"web-haptics": "^0.0.6"
	},
	"devDependencies": {
		"@biomejs/biome": "1.7.2",
		"@tailwindcss/typography": "^0.5.20"
	}
}
